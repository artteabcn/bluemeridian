---
import { ensureDocumentsTable } from '../lib/documents-table';

const db = Astro.locals.runtime.env.DB;
const r2 = (Astro.locals.runtime.env as any).FILES;

let message = '';
let messageType: 'success' | 'error' = 'success';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = String(fd.get('action') ?? '');
  try {
    if (action === 'add') {
      await db.prepare('INSERT INTO shareholders (name, jurisdiction, percentage) VALUES (?,?,?)')
        .bind(String(fd.get('name')), String(fd.get('jurisdiction')), parseFloat(String(fd.get('percentage'))))
        .run();
      message = 'Shareholder added to the registry.';
    } else if (action === 'update') {
      await db.prepare('UPDATE shareholders SET name=?, jurisdiction=?, percentage=? WHERE id=?')
        .bind(String(fd.get('name')), String(fd.get('jurisdiction')), parseFloat(String(fd.get('percentage'))), Number(fd.get('id')))
        .run();
      message = 'Registry entry updated.';
    } else if (action === 'delete') {
      const id = Number(fd.get('id'));
      if (r2) {
        try {
          const { results: docs } = await db.prepare('SELECT r2_key FROM documents WHERE shareholder_id=?').bind(id).all();
          for (const doc of docs as any[]) await r2.delete(doc.r2_key).catch(() => {});
          await db.prepare('DELETE FROM documents WHERE shareholder_id=?').bind(id).run();
        } catch { /* documents table may not exist yet */ }
      }
      await db.prepare('DELETE FROM shareholders WHERE id=?').bind(id).run();
      message = 'Shareholder removed from the registry.';
    }
  } catch (e: any) {
    message = 'Error: ' + e.message;
    messageType = 'error';
  }
}

await ensureDocumentsTable(db);

const { results: shareholders } = await db.prepare('SELECT * FROM shareholders ORDER BY id').all() as {
  results: Array<{ id: number; name: string; jurisdiction: string; percentage: number }>;
};
const { results: allDocuments } = await db.prepare('SELECT * FROM documents ORDER BY uploaded_at DESC').all() as {
  results: Array<{ id: number; shareholder_id: number; file_name: string; doc_type: string; file_size: number; uploaded_at: string }>;
};

const totalPct = shareholders.reduce((s, sh) => s + sh.percentage, 0);
const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

function formatSize(bytes: number | null | undefined): string {
  if (!bytes) return '';
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1048576) return `${(bytes / 1024).toFixed(0)} KB`;
  return `${(bytes / 1048576).toFixed(1)} MB`;
}

function formatDate(iso: string): string {
  try { return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); }
  catch { return iso; }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blue Meridian Fisheries — Shareholder Ledger</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #060d14;
      --surface:  #0b1928;
      --surface2: #0f2437;
      --border:   rgba(201,169,110,.14);
      --border2:  rgba(255,255,255,.06);
      --gold:     #c9a96e;
      --gold-d:   #8a6d3b;
      --gold-l:   #e8d5a3;
      --text:     #f0ede8;
      --muted:    #4a6580;
      --muted2:   #2d4560;
      --green:    #3dd68c;
      --red:      #f86b6b;
      --ease:     cubic-bezier(.32,.72,0,1);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100dvh;
      padding: 52px 28px 80px;
    }

    .wrap { max-width: 1080px; margin: 0 auto; }

    /* ── Header ─────────────────────────────────────── */
    .hdr {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding-bottom: 36px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 44px;
    }
    .eyebrow {
      display: inline-block;
      font-size: 9.5px;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(201,169,110,.3);
      border-radius: 100px;
      padding: 3px 10px;
      margin-bottom: 14px;
      font-weight: 500;
    }
    .hdr h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 52px;
      font-weight: 600;
      letter-spacing: -.02em;
      line-height: 1;
      color: var(--text);
    }
    .hdr-sub { font-size: 12px; color: var(--muted); margin-top: 10px; letter-spacing: .02em; }
    .hdr-right { text-align: right; }
    .hdr-date { font-size: 11.5px; color: var(--muted); margin-bottom: 8px; }
    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10.5px;
      font-weight: 500;
      color: var(--green);
      background: rgba(61,214,140,.08);
      border: 1px solid rgba(61,214,140,.22);
      border-radius: 100px;
      padding: 4px 10px;
    }
    .dot {
      width: 5px; height: 5px;
      background: var(--green);
      border-radius: 50%;
      animation: pulse 2.4s infinite;
    }
    @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:.35 } }

    /* ── Stats ───────────────────────────────────────── */
    .stats {
      display: grid;
      grid-template-columns: 1fr 1fr 2fr;
      gap: 14px;
      margin-bottom: 44px;
    }
    .stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 22px 24px;
    }
    .stat-val {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: 42px;
      font-weight: 600;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-lbl {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: var(--muted);
    }
    .stat-bar {
      display: flex;
      flex-direction: column;
      gap: 14px;
      justify-content: center;
    }
    .bar-head { display: flex; justify-content: space-between; }
    .bar-track {
      height: 5px;
      background: rgba(255,255,255,.05);
      border-radius: 100px;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--gold-d), var(--gold));
      border-radius: 100px;
      transition: width .9s var(--ease);
    }

    /* ── Toast ───────────────────────────────────────── */
    .toast {
      border-radius: 8px;
      padding: 11px 16px;
      font-size: 13px;
      margin-bottom: 24px;
      background: rgba(61,214,140,.08);
      border: 1px solid rgba(61,214,140,.22);
      color: var(--green);
    }
    .toast.error {
      background: rgba(248,107,107,.08);
      border-color: rgba(248,107,107,.22);
      color: var(--red);
    }

    /* ── Registry card ──────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 20px;
    }
    .card-hdr {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 24px;
      border-bottom: 1px solid var(--border);
    }
    .card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 17px;
      font-weight: 600;
    }
    .card-tag {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--muted);
    }

    /* ── Table ───────────────────────────────────────── */
    .t-head {
      display: grid;
      grid-template-columns: 3fr 2fr 110px auto;
      padding: 9px 24px;
      border-bottom: 1px solid var(--border);
      font-size: 9.5px;
      text-transform: uppercase;
      letter-spacing: .16em;
      color: var(--muted);
      font-weight: 500;
    }
    .sh-block { border-bottom: 1px solid var(--border); }
    .sh-block:last-child { border-bottom: none; }

    .sh-row {
      display: grid;
      grid-template-columns: 3fr 2fr 110px auto;
      align-items: center;
      gap: 10px;
      padding: 13px 24px;
      transition: background .2s var(--ease);
    }
    .sh-row:hover { background: rgba(201,169,110,.025); }

    .sh-row input[type="text"],
    .sh-row input[type="number"] {
      width: 100%;
      background: rgba(6,13,20,.7);
      border: 1px solid rgba(201,169,110,.14);
      border-radius: 7px;
      padding: 7px 10px;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      color: var(--text);
      outline: none;
      transition: border-color .25s, box-shadow .25s;
    }
    .sh-row input:focus {
      border-color: rgba(201,169,110,.5);
      box-shadow: 0 0 0 3px rgba(201,169,110,.07);
    }
    .pct-wrap { display: flex; align-items: center; gap: 4px; }
    .pct-wrap input { width: 68px !important; text-align: right; }
    .pct-sym { color: var(--muted); font-size: 13px; }

    .cell-act { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }

    /* ── Buttons ─────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 6px 11px;
      border-radius: 7px;
      font-family: 'DM Sans', sans-serif;
      font-size: 11.5px;
      font-weight: 500;
      border: none;
      cursor: pointer;
      text-decoration: none;
      white-space: nowrap;
      transition: all .22s var(--ease);
    }
    .btn-save {
      background: rgba(201,169,110,.14);
      color: var(--gold);
      border: 1px solid rgba(201,169,110,.28);
    }
    .btn-save:hover { background: rgba(201,169,110,.24); }

    .btn-cert {
      background: rgba(15,37,55,.9);
      color: var(--gold-l);
      border: 1px solid rgba(201,169,110,.18);
    }
    .btn-cert:hover { background: rgba(201,169,110,.1); }

    .btn-remove {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border2);
    }
    .btn-remove:hover { background: rgba(248,107,107,.1); color: var(--red); border-color: rgba(248,107,107,.28); }

    .btn-docs {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border2);
    }
    .btn-docs:hover, .btn-docs.active { background: rgba(255,255,255,.05); color: var(--text); }

    /* ── Documents panel ─────────────────────────────── */
    .docs-panel {
      display: none;
      background: rgba(4,10,18,.5);
      border-top: 1px solid var(--border);
      padding: 18px 24px;
    }
    .docs-panel.open {
      display: block;
      animation: slideIn .22s var(--ease);
    }
    @keyframes slideIn {
      from { opacity:0; transform:translateY(-6px) }
      to   { opacity:1; transform:translateY(0) }
    }

    .docs-list { display: flex; flex-direction: column; gap: 7px; margin-bottom: 16px; }
    .docs-empty { font-size: 12px; color: var(--muted); font-style: italic; padding: 4px 0 10px; }

    .doc-item {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      background: rgba(255,255,255,.025);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 12px;
    }
    .doc-badge {
      font-size: 9.5px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--gold);
      background: rgba(201,169,110,.1);
      border: 1px solid rgba(201,169,110,.22);
      border-radius: 4px;
      padding: 2px 6px;
      white-space: nowrap;
    }
    .doc-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--text); }
    .doc-meta { color: var(--muted); font-size: 10.5px; white-space: nowrap; }
    .doc-dl {
      color: var(--gold);
      font-size: 11px;
      font-weight: 500;
      text-decoration: none;
      white-space: nowrap;
    }
    .doc-dl:hover { text-decoration: underline; }
    .doc-del {
      background: transparent;
      border: none;
      cursor: pointer;
      color: var(--muted2);
      font-size: 15px;
      line-height: 1;
      padding: 0 2px;
      transition: color .18s;
    }
    .doc-del:hover { color: var(--red); }

    /* ── Upload form ─────────────────────────────────── */
    .upload-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .upload-lbl {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: var(--muted);
      white-space: nowrap;
    }
    .upload-row input[type="file"] {
      flex: 1;
      min-width: 200px;
      font-size: 12px;
      color: var(--text);
      background: rgba(6,13,20,.7);
      border: 1px solid rgba(201,169,110,.14);
      border-radius: 7px;
      padding: 6px 8px;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
    }
    .upload-row select {
      font-size: 12px;
      color: var(--text);
      background: rgba(6,13,20,.9);
      border: 1px solid rgba(201,169,110,.14);
      border-radius: 7px;
      padding: 7px 10px;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      outline: none;
    }
    .btn-upload {
      background: rgba(201,169,110,.14);
      color: var(--gold);
      border: 1px solid rgba(201,169,110,.28);
      border-radius: 7px;
      padding: 7px 14px;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      white-space: nowrap;
      transition: background .2s;
    }
    .btn-upload:hover { background: rgba(201,169,110,.24); }

    /* ── Add form ────────────────────────────────────── */
    .add-block {
      display: none;
      border-top: 1px solid var(--border);
      background: rgba(201,169,110,.02);
    }
    .add-block.open { display: block; animation: slideIn .22s var(--ease); }

    /* ── Footer actions ──────────────────────────────── */
    .ftr-act { display: flex; justify-content: flex-end; margin-bottom: 48px; }
    .btn-add {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--gold);
      color: #060d14;
      border: none;
      border-radius: 9px;
      padding: 10px 20px;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all .22s var(--ease);
    }
    .btn-add:hover { background: var(--gold-l); transform: translateY(-1px); }
    .btn-add.hide { display: none; }

    /* ── Page footer ─────────────────────────────────── */
    .page-ftr {
      padding-top: 28px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
      color: var(--muted);
    }

    /* ── Responsive ──────────────────────────────────── */
    @media (max-width: 768px) {
      body { padding: 28px 16px 60px; }
      .hdr { flex-direction: column; gap: 16px; }
      .hdr h1 { font-size: 38px; }
      .hdr-right { text-align: left; }
      .stats { grid-template-columns: 1fr 1fr; }
      .stat-bar { grid-column: 1 / -1; }
      .t-head { display: none; }
      .sh-row { grid-template-columns: 1fr; }
      .cell-act { flex-wrap: wrap; }
      .page-ftr { flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>
<div class="wrap">

  <!-- Header -->
  <header class="hdr">
    <div>
      <span class="eyebrow">Delaware Corporation · Est. 2026</span>
      <h1>Blue Meridian Fisheries</h1>
      <p class="hdr-sub">Internal Shareholder Ledger &amp; Registry Management Portal · File No. DE 10677862</p>
    </div>
    <div class="hdr-right">
      <div class="hdr-date">{today}</div>
      <div class="status-pill"><span class="dot"></span> Active Registry</div>
    </div>
  </header>

  <!-- Stats -->
  <div class="stats">
    <div class="stat">
      <span class="stat-val">{shareholders.length}</span>
      <span class="stat-lbl">Registered Entities</span>
    </div>
    <div class="stat">
      <span class="stat-val">{totalPct.toFixed(1)}%</span>
      <span class="stat-lbl">Equity Allocated</span>
    </div>
    <div class="stat stat-bar">
      <div class="bar-head">
        <span class="stat-lbl">Capital Distribution</span>
        <span class="stat-lbl">{totalPct.toFixed(1)} / 100%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill" style={`width:${Math.min(totalPct,100)}%`}></div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  {message && <div class={`toast${messageType === 'error' ? ' error' : ''}`}>{message}</div>}

  <!-- Registry card -->
  <div class="card">
    <div class="card-hdr">
      <span class="card-title">Shareholder Registry</span>
      <span class="card-tag">Incorporators &amp; Equity Holders</span>
    </div>

    <!-- Column headers -->
    <div class="t-head">
      <div>Entity Name</div>
      <div>Jurisdiction</div>
      <div>Equity</div>
      <div>Actions</div>
    </div>

    <!-- Shareholder rows -->
    {shareholders.map((sh) => {
      const shDocs = allDocuments.filter(d => d.shareholder_id === sh.id);
      return (
        <div class="sh-block" id={`sh-${sh.id}`}>
          <form method="POST" class="sh-row">
            <input type="hidden" name="id" value={sh.id} />
            <div>
              <input type="text" name="name" value={sh.name} placeholder="Entity name" required />
            </div>
            <div>
              <input type="text" name="jurisdiction" value={sh.jurisdiction} placeholder="Jurisdiction" required />
            </div>
            <div class="pct-wrap">
              <input type="number" step="0.01" min="0" max="100" name="percentage" value={sh.percentage} required />
              <span class="pct-sym">%</span>
            </div>
            <div class="cell-act">
              <a href={`/api/certificate/${sh.id}`} target="_blank" class="btn btn-cert">Certificate</a>
              <button type="submit" name="action" value="update" class="btn btn-save">Save</button>
              <button
                type="submit"
                name="action"
                value="delete"
                class="btn btn-remove"
                onclick="return confirm('Permanently remove this shareholder and all their documents from the registry?')"
              >Remove</button>
              <button
                type="button"
                class="btn btn-docs"
                id={`toggle-${sh.id}`}
                onclick={`toggleDocs(${sh.id})`}
              >
                Docs {shDocs.length > 0 ? `(${shDocs.length})` : ''}
              </button>
            </div>
          </form>

          <!-- Documents panel -->
          <div class="docs-panel" id={`docs-${sh.id}`}>
            <div class="docs-list">
              {shDocs.length === 0
                ? <p class="docs-empty">No documents uploaded yet.</p>
                : shDocs.map(doc => (
                    <div class="doc-item">
                      <span class="doc-badge">{doc.doc_type}</span>
                      <span class="doc-name" title={doc.file_name}>{doc.file_name}</span>
                      <span class="doc-meta">{formatSize(doc.file_size)}</span>
                      <span class="doc-meta">{formatDate(doc.uploaded_at)}</span>
                      <a href={`/api/documents/${sh.id}/${doc.id}`} class="doc-dl">Download</a>
                      <form method="POST" action={`/api/documents/${sh.id}/${doc.id}`} style="display:inline">
                        <input type="hidden" name="action" value="delete" />
                        <button
                          type="submit"
                          class="doc-del"
                          title="Delete document"
                          onclick="return confirm('Delete this document?')"
                        >×</button>
                      </form>
                    </div>
                  ))
              }
            </div>
            <form
              method="POST"
              action={`/api/documents/${sh.id}`}
              enctype="multipart/form-data"
              class="upload-row"
            >
              <span class="upload-lbl">Upload</span>
              <input type="file" name="file" required />
              <select name="docType">
                <option value="Passport">Passport</option>
                <option value="Certificate">Certificate</option>
                <option value="Other">Other</option>
              </select>
              <button type="submit" class="btn-upload">Upload</button>
            </form>
          </div>
        </div>
      );
    })}

    <!-- Add shareholder form (hidden by default) -->
    <div class="add-block" id="add-block">
      <form method="POST" class="sh-row">
        <div>
          <input type="text" name="name" placeholder="Entity name" required />
        </div>
        <div>
          <input type="text" name="jurisdiction" placeholder="Jurisdiction" required />
        </div>
        <div class="pct-wrap">
          <input type="number" step="0.01" min="0" max="100" name="percentage" placeholder="0.00" required />
          <span class="pct-sym">%</span>
        </div>
        <div class="cell-act">
          <button type="submit" name="action" value="add" class="btn btn-save">Add</button>
          <button type="button" class="btn btn-remove" onclick="closeAdd()">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Add shareholder button -->
  <div class="ftr-act">
    <button class="btn-add" id="btn-add" onclick="openAdd()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="7" y1="2" x2="7" y2="12"/><line x1="2" y1="7" x2="12" y2="7"/>
      </svg>
      Add Shareholder
    </button>
  </div>

  <!-- Page footer -->
  <footer class="page-ftr">
    <span>Blue Meridian Fisheries Corporation · Delaware · DE 10677862</span>
    <span>Confidential — Internal Registry Portal</span>
  </footer>

</div>

<script is:inline>
  function toggleDocs(id) {
    const panel = document.getElementById('docs-' + id);
    const btn   = document.getElementById('toggle-' + id);
    const open  = panel.classList.toggle('open');
    btn.classList.toggle('active', open);
  }

  function openAdd() {
    document.getElementById('add-block').classList.add('open');
    document.getElementById('btn-add').classList.add('hide');
    document.querySelector('#add-block input[name="name"]').focus();
  }

  function closeAdd() {
    document.getElementById('add-block').classList.remove('open');
    document.getElementById('btn-add').classList.remove('hide');
  }
</script>
</body>
</html>
